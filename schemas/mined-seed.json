{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jonesrussell.github.io/blog/schemas/mined-seed.json",
  "title": "Mined Seed",
  "description": "A content seed produced by the mining stage of the content pipeline.",
  "type": "object",
  "required": ["source", "source_ref", "content_seed", "suggested_type", "suggested_channels", "mined_at", "confidence"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "enum": ["git-commit", "github-milestone", "design-spec", "blog-post", "north-cloud"],
      "description": "Where the seed came from."
    },
    "source_ref": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      ],
      "description": "Commit SHA, issue URL, file path, or North Cloud article ID. May be a single value or an array for grouped commits."
    },
    "content_seed": {
      "type": "string",
      "minLength": 1,
      "description": "The raw idea or excerpt."
    },
    "suggested_type": {
      "type": "string",
      "enum": ["text-post", "blog-post", "video", "newsletter"],
      "description": "Recommended content type."
    },
    "suggested_channels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["facebook", "linkedin", "bluesky", "devto", "substack", "youtube"]
      },
      "minItems": 1,
      "description": "Recommended distribution channels."
    },
    "mined_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when mining occurred."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Signal strength (0-1). Optional."
    }
  }
}
